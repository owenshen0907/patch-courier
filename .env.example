# Codex executable
# Set this if Codex is not installed in one of the default probe locations.
CODEX_CLI_PATH=/absolute/path/to/codex

# Mailroom runtime storage
MAILROOM_SUPPORT_ROOT="$HOME/Library/Application Support/PatchCourier"
MAILROOM_DATABASE_PATH="$HOME/Library/Application Support/PatchCourier/mailroom.sqlite3"
MAILROOM_CODEX_HOME="$HOME/Library/Application Support/PatchCourier/CodexHome"
MAILROOM_CODEX_PROFILE_HOME="$HOME/.codex"

# Optional defaults for daemon-launched work
MAILROOM_WORKSPACE_ROOT=/path/to/workspaces
MAILROOM_WORKDIR=/path/to/patch-courier
MAILROOM_TRANSPORT_SCRIPT_PATH="$HOME/Library/Application Support/PatchCourier/runtime-tools/mail_transport.py"
MAILROOM_ACCOUNTS_PATH="$HOME/Library/Application Support/PatchCourier/mailbox-accounts.json"
MAILROOM_POLICIES_PATH="$HOME/Library/Application Support/PatchCourier/sender-policies.json"
