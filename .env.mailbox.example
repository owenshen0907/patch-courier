# Mailbox-enabled profile. Copy to .env.local, then run:
#   set -a; source .env.local; set +a
# Mailbox account, sender policy, managed project, and password are configured in the macOS app.
# Do not put mailbox passwords in this file.

PATCH_COURIER_ROOT="${PATCH_COURIER_ROOT:-$PWD}"

# Set this only if Codex is not in a default location such as /opt/homebrew/bin/codex.
# CODEX_CLI_PATH=/absolute/path/to/codex

MAILROOM_SUPPORT_ROOT="$HOME/Library/Application Support/PatchCourier"
MAILROOM_DATABASE_PATH="$HOME/Library/Application Support/PatchCourier/mailroom.sqlite3"
MAILROOM_CODEX_HOME="$HOME/Library/Application Support/PatchCourier/CodexHome"
MAILROOM_CODEX_PROFILE_HOME="$HOME/.codex"
MAILROOM_WORKDIR="$PATCH_COURIER_ROOT"
MAILROOM_WORKSPACE_ROOT="$HOME/MyCodeSpace"
MAILROOM_TRANSPORT_SCRIPT_PATH="$HOME/Library/Application Support/PatchCourier/runtime-tools/mail_transport.py"
MAILROOM_ACTIVE_TURN_RECOVERY_POLL_SECONDS=30
MAILROOM_ACTIVE_TURN_RECOVERY_TIMEOUT_SECONDS=21600
