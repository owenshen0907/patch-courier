# Local-only probe profile. Copy to .env.local, then run:
#   set -a; source .env.local; set +a
# This profile avoids real mailbox polling and keeps generated state inside the repo.

PATCH_COURIER_ROOT="${PATCH_COURIER_ROOT:-$PWD}"

# Set this only if Codex is not in a default location such as /opt/homebrew/bin/codex.
# CODEX_CLI_PATH=/absolute/path/to/codex

MAILROOM_SUPPORT_ROOT="$PATCH_COURIER_ROOT/.local/support"
MAILROOM_DATABASE_PATH="$PATCH_COURIER_ROOT/.local/support/mailroom.sqlite3"
MAILROOM_CODEX_HOME="$PATCH_COURIER_ROOT/.local/support/CodexHome"
MAILROOM_CODEX_PROFILE_HOME="$HOME/.codex"
MAILROOM_WORKDIR="$PATCH_COURIER_ROOT"
MAILROOM_WORKSPACE_ROOT="$PATCH_COURIER_ROOT"
MAILROOM_TRANSPORT_SCRIPT_PATH="$PATCH_COURIER_ROOT/.local/support/runtime-tools/mail_transport.py"
